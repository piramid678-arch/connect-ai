        "from transformers import AutoModelForCausalLM, AutoTokenizer\n",
        "import torch\n",
        "\n",
        "tok = AutoTokenizer.from_pretrained('./merged_model')\n",
        "model = AutoModelForCausalLM.from_pretrained('./merged_model', torch_dtype=torch.bfloat16, device_map='auto')\n",
        "\n",
        "def ask(q, lang='ko'):\n",
        "    if lang == 'ko':\n",
        "        sys_msg = \"당신은 한국어만 사용하는 AI입니다. 모든 답변을 반드시 한국어로만 작성하세요. 영어나 중국어는 절대 사용하지 마세요.\"\n",
        "    else:\n",
        "        sys_msg = \"You are a helpful AI assistant. Please answer in English.\"\n",
        "\n",
        "    msgs = [\n",
        "        {'role': 'system', 'content': sys_msg},\n",
        "        {'role': 'user', 'content': q}\n",
        "    ]\n",
        "\n",
        "    inputs = tok.apply_chat_template(msgs, add_generation_prompt=True, return_tensors='pt').to(model.device)\n",
        "\n",
        "    # 여기서 파라미터를 조절합니다.\n",
        "    out = model.generate(\n",
        "        **inputs,\n",
        "        max_new_tokens=400,\n",
        "        temperature=0.7, # <--- 이 값을 0.1(보수적)에서 1.0(창의적) 사이로 조절해보세요.\n",
        "        top_p=0.9,\n",
        "        do_sample=True,\n",
        "        repetition_penalty=1.5,\n",
        "        no_repeat_ngram_size=3\n",
        "    )\n",
        "\n",
        "    response = tok.decode(out[0][inputs['input_ids'].shape[-1]:], skip_special_tokens=True)\n",
        "    print(response)\n",
        "\n",
        "print('=== 한국어 테스트 ==='); ask('1인 기업가에게 좋은 아침 루틴 3가지 추천해줘', lang='ko')\n",
        "print('\\n=== English Test ==='); ask('Give me a simple python code for a fibonacci function.', lang='en')"
      ]
    },
